{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "paths": {
      "@rhi-zone/fractal-api-tree/node": ["../../packages/api-tree/src/node.ts"],
      "@rhi-zone/fractal-api-tree/tags": ["../../packages/api-tree/src/tags.ts"],
      "@rhi-zone/fractal-http-api-projector/preset": ["../../packages/http-api-projector/src/preset.ts"],
      "@rhi-zone/fractal-http-api-projector/project": ["../../packages/http-api-projector/src/project.ts"],
      "@rhi-zone/fractal-mcp-api-projector": ["../../packages/mcp-api-projector/src/index.ts"],
      "@rhi-zone/fractal-api-tree/tree": ["../../packages/api-tree/src/tree.ts"]
    }
  },
  "include": ["src"]
}
