{
  "compilerOptions": {
    "strict": true,
    "strictFunctionTypes": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types"],
    "noEmit": true
  },
  "include": ["std.ts", "app.ts", "app.test.ts"]
}
