{
  "name": "@rhi-zone/fractal-client-api-projector",
  "version": "0.1.0-alpha.0",
  "description": "Runtime HTTP client derived from the HttpRoute tree — method/path mirror the server's route dispatch exactly, since both walk the same projected tree",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*",
    "@rhi-zone/fractal-http-api-projector": "workspace:*",
    "@rhi-zone/fractal-example-library-api": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
