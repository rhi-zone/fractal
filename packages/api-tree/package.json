{
  "name": "@rhi-zone/fractal-api-tree",
  "version": "0.1.0-alpha.0",
  "description": "Function-core model — function category (Fn/compose/pipe) + Result + Kleisli/applicative combinators (composeK/collect); Node/Op/Meta model in ./node; Tags lattice in ./tags",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts"
    },
    "./tags": {
      "types": "./src/tags.ts",
      "import": "./src/tags.ts"
    },
    "./tree": {
      "types": "./src/tree.ts",
      "import": "./src/tree.ts"
    },
    "./extract": {
      "types": "./src/extract.ts",
      "import": "./src/extract.ts"
    }
  },
  "files": ["src"],
  "bin": {
    "fractal-api-tree": "./src/cli.ts"
  },
  "dependencies": {
    "@rhi-zone/fractal-type-ir": "workspace:*"
  },
  "devDependencies": {
    "@rhi-zone/fractal-cli-api-projector": "workspace:*",
    "@rhi-zone/fractal-mcp-api-projector": "workspace:*",
    "@sinclair/typebox": "^0.34.41",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
