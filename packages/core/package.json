{
  "name": "@rhi-zone/fractal-core",
  "version": "0.1.0-alpha.0",
  "description": "Inert-data node IR, capability contracts, Context, combinator surface",
  "type": "module",
  "main": "./dist/core.umd.cjs",
  "module": "./dist/core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/core.js",
      "require": "./dist/core.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "vite":       "^6.0.0",
    "vitest":     "^2.0.0"
  }
}
