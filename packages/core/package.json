{
  "name": "@rhi-zone/fractal-core",
  "version": "0.1.0-alpha.0",
  "description": "Routing algebra — Handler, path/methods/choice/mount/param, inert .meta reflection, StandardSchema (types)",
  "type": "module",
  "main": "./dist/core.umd.cjs",
  "module": "./dist/core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/core.js",
      "require": "./dist/core.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "vite":    "^6.0.0"
  }
}
