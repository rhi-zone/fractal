{
  "name": "@rhi-zone/fractal-openapi",
  "version": "0.1.0-alpha.0",
  "description": "OpenAPI 3.x projection derived from an app's inert .meta — code-first, the handler tree is the source of truth",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":  "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@rhi-zone/fractal-core": "workspace:*"
  },
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@rhi-zone/fractal-http": "workspace:*",
    "vite": "^6.0.0"
  }
}
