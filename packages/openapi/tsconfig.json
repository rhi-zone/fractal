{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "paths": {
      "@rhi-zone/fractal-core": ["../core/src/index.ts"],
      "@rhi-zone/fractal-core/node": ["../core/src/node.ts"],
      "@rhi-zone/fractal-core/tags": ["../core/src/tags.ts"],
      "@rhi-zone/fractal-http": ["../http/src/index.ts"],
      "@rhi-zone/fractal-http/project": ["../http/src/project.ts"],
      "@rhi-zone/fractal-codegen": ["../codegen/src/index.ts"]
    }
  },
  "include": ["src"]
}
