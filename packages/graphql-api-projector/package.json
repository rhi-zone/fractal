{
  "name": "@rhi-zone/fractal-graphql-api-projector",
  "version": "0.1.0-alpha.0",
  "description": "GraphQL projection for the function-core tree — nested Query / flat Mutation+Subscription SDL assembly (via @rhi-zone/fractal-type-ir) + graphql-js resolver dispatch",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./project": {
      "types": "./src/project.ts",
      "import": "./src/project.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./resolve": {
      "types": "./src/resolve.ts",
      "import": "./src/resolve.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./presets": {
      "types": "./src/presets.ts",
      "import": "./src/presets.ts"
    },
    "./ws": {
      "types": "./src/ws.ts",
      "import": "./src/ws.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*",
    "@rhi-zone/fractal-type-ir": "workspace:*",
    "graphql": "^16.9.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
