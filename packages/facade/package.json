{
  "name": "@rhi-zone/fractal-facade",
  "version": "0.1.0-alpha.0",
  "description": "Aggregator re-export — user-facing entry point",
  "type": "module",
  "main": "./dist/facade.umd.cjs",
  "module": "./dist/facade.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/facade.js",
      "require": "./dist/facade.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rhi-zone/fractal-core":                    "workspace:*",
    "@rhi-zone/fractal-transport":               "workspace:*",
    "@rhi-zone/fractal-codec-json":              "workspace:*",
    "@rhi-zone/fractal-codec-structured-clone":  "workspace:*",
    "@rhi-zone/fractal-protocol-correlation":    "workspace:*",
    "@rhi-zone/fractal-channel-http":            "workspace:*",
    "@rhi-zone/fractal-channel-websocket":       "workspace:*",
    "@rhi-zone/fractal-channel-worker":          "workspace:*",
    "@rhi-zone/fractal-channel-stdio":           "workspace:*",
    "@rhi-zone/fractal-schema":                  "workspace:*",
    "@rhi-zone/fractal-preset-websocket":        "workspace:*"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "vite":       "^6.0.0",
    "vitest":     "^2.0.0"
  }
}
