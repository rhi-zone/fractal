{
  "name": "@rhi-zone/fractal-codegen",
  "version": "0.1.0-alpha.0",
  "description": "Build-time extractor — derive runtime JSON-Schema + descriptions from op input types and JSDoc via the TypeScript compiler API (obvious cases; punts exotics)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": { "fractal-codegen": "./src/cli.ts" },
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" }
  },
  "files": ["src"],
  "dependencies": {
    "typescript": "^6.0.3",
    "@rhi-zone/fractal-type-ir": "workspace:*"
  },
  "devDependencies": {
    "@rhi-zone/fractal-core": "workspace:*",
    "@rhi-zone/fractal-mcp": "workspace:*",
    "@sinclair/typebox": "^0.34.41"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
