{
  "name": "@rhi-zone/fractal-preset-websocket",
  "version": "0.1.0-alpha.0",
  "description": "Convenience preset: wsClient + serveWs over compose/attach (sugar only — compose directly for full control)",
  "type": "module",
  "main": "./dist/preset-websocket.umd.cjs",
  "module": "./dist/preset-websocket.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/preset-websocket.js",
      "require": "./dist/preset-websocket.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rhi-zone/fractal-transport":            "workspace:*",
    "@rhi-zone/fractal-channel-websocket":    "workspace:*",
    "@rhi-zone/fractal-codec-json":           "workspace:*",
    "@rhi-zone/fractal-protocol-correlation": "workspace:*"
  },
  "devDependencies": {
    "@rhi-zone/fractal-core":                 "workspace:*",
    "fast-check": "^4.5.3",
    "vite":       "^6.0.0",
    "vitest":     "^2.0.0"
  }
}
