{
  "name": "@rhi-zone/fractal-type-ir",
  "version": "0.1.0-alpha.0",
  "description": "Type IR — subtyping hierarchy + open metadata bag for projections (JSON Schema, OpenAPI, SQL DDL, etc.)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./json-schema": {
      "types": "./src/json-schema.ts",
      "import": "./src/json-schema.ts"
    },
    "./jsdoc": {
      "types": "./src/jsdoc.ts",
      "import": "./src/jsdoc.ts"
    },
    "./json-schema-07": {
      "types": "./src/json-schema-07.ts",
      "import": "./src/json-schema-07.ts"
    },
    "./openapi30": {
      "types": "./src/openapi30.ts",
      "import": "./src/openapi30.ts"
    },
    "./typescript": {
      "types": "./src/typescript.ts",
      "import": "./src/typescript.ts"
    },
    "./sql": {
      "types": "./src/sql.ts",
      "import": "./src/sql.ts"
    },
    "./protobuf": {
      "types": "./src/protobuf.ts",
      "import": "./src/protobuf.ts"
    },
    "./capnp": {
      "types": "./src/capnp.ts",
      "import": "./src/capnp.ts"
    },
    "./jtd": {
      "types": "./src/jtd.ts",
      "import": "./src/jtd.ts"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "import": "./src/zod.ts"
    },
    "./arktype": {
      "types": "./src/arktype.ts",
      "import": "./src/arktype.ts"
    },
    "./typebox": {
      "types": "./src/typebox.ts",
      "import": "./src/typebox.ts"
    },
    "./valibot": {
      "types": "./src/valibot.ts",
      "import": "./src/valibot.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
