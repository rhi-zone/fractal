  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*",
    "@rhi-zone/fractal-type-ir": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
