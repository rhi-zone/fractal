{
  "name": "@rhi-zone/fractal-cli-api-projector",
  "version": "0.1.0-alpha.0",
  "description": "CLI projection for the function-core tree — subcommand dispatch, tag-driven confirm, codegen args",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
