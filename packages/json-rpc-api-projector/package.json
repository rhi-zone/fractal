{
  "name": "@rhi-zone/fractal-json-rpc-api-projector",
  "version": "0.1.0-alpha.0",
  "description": "JSON-RPC 2.0 method projection for the function-core tree — dot-joined method names, HTTP POST + WebSocket transports, batch requests, streaming via Notifications, typed client",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./project": {
      "types": "./src/project.ts",
      "import": "./src/project.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./wire": {
      "types": "./src/wire.ts",
      "import": "./src/wire.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*",
    "@rhi-zone/fractal-type-ir": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
