{
  "name": "@rhi-zone/fractal-schema",
  "version": "0.1.0-alpha.0",
  "description": "OpenAPI/JSON Schema/doc generation (zero runtime deps)",
  "type": "module",
  "main": "./dist/schema.umd.cjs",
  "module": "./dist/schema.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/schema.js",
      "require": "./dist/schema.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rhi-zone/fractal-core": "workspace:*"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "vite":       "^6.0.0",
    "vitest":     "^2.0.0"
  }
}
