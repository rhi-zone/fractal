{
  "name": "@rhi-zone/fractal-client",
  "version": "0.1.0-alpha.0",
  "description": "Typed client derived from a fractal Node route tree — in-process + HTTP transports",
  "type": "module",
  "main": "./dist/client.umd.cjs",
  "module": "./dist/client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/client.js",
      "require": "./dist/client.umd.cjs"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@rhi-zone/fractal-core": "workspace:*",
    "@rhi-zone/fractal-http": "workspace:*"
  },
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vite":   "^6.0.0",
    "vitest": "^2.0.0"
  }
}
