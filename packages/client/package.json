{
  "name": "@rhi-zone/fractal-client",
  "version": "0.1.0-alpha.0",
  "description": "Runtime HTTP client derived from the function-core tree — method/path mirror the server's tree-walk dispatch (verbFromTags) so routes match exactly",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-core": "workspace:*",
    "@rhi-zone/fractal-http": "workspace:*",
    "@rhi-zone/fractal-example-library-api": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
