{
  "name": "@rhi-zone/fractal-client",
  "version": "0.1.0-alpha.0",
  "description": "Typed client derived from a fractal router — end-to-end inference, in-process + http transports",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":  "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@rhi-zone/fractal-core": "workspace:*",
    "@rhi-zone/fractal-http": "workspace:*"
  },
  "scripts": {
    "dev":        "vite build --watch",
    "build":      "vite build && tsgo --emitDeclarationOnly",
    "typecheck":  "tsgo --noEmit",
    "test":       "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
