{
  "name": "@rhi-zone/fractal-http-api-projector",
  "version": "0.1.0-alpha.0",
  "description": "WHATWG renderer for the function-core tree — direct tree-walk makeRouter, autoMethodLayer, corsLayer, createFetch, serveBun/serveNode",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./adapter": {
      "types": "./src/adapter.ts",
      "import": "./src/adapter.ts"
    },
    "./dx": {
      "types": "./src/dx.ts",
      "import": "./src/dx.ts"
    },
    "./preset": {
      "types": "./src/preset.ts",
      "import": "./src/preset.ts"
    },
    "./project": {
      "types": "./src/project.ts",
      "import": "./src/project.ts"
    },
    "./route": {
      "types": "./src/route.ts",
      "import": "./src/route.ts"
    },
    "./layers": {
      "types": "./src/layers.ts",
      "import": "./src/layers.ts"
    },
    "./verbs": {
      "types": "./src/verbs.ts",
      "import": "./src/verbs.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
