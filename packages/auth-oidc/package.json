{
  "name": "@rhi-zone/fractal-auth-oidc",
  "version": "0.1.0-alpha.0",
  "description": "Generic OIDC/JWT auth adapter for fractal — server-side JWKS-backed JWT validation (AuthAdapter) and client-side OAuth token lifecycle management (AuthClientAdapter), both via Web Crypto (no JWT library dependency)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./jwt": {
      "types": "./src/jwt.ts",
      "import": "./src/jwt.ts"
    },
    "./jwks": {
      "types": "./src/jwks.ts",
      "import": "./src/jwks.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@rhi-zone/fractal-api-tree": "workspace:*"
  },
  "devDependencies": {
    "@rhi-zone/fractal-http-api-projector": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
